<div class="container login-container">
  <div class="header">
    <div class="brand">
      <h1 style="margin:0;">Back2Coder</h1>
      <span class="badge">Store</span>
    </div>
  </div>

  <div class="card">
    <div class="login-section">
      <h3>Iniciar sesion</h3>
      <input id="loginUsername" class="input" type="text" placeholder="Tu username" />
      <button id="btnLogin" class="btn btn--primary" type="button" style="width:100%;">Ingresar</button>
    </div>

    <hr class="hr" />

    <div class="login-section">
      <h3>Crear cuenta</h3>
      <input id="regUsername" class="input" type="text" placeholder="Username" />
      <input id="regNombre" class="input" type="text" placeholder="Nombre completo" />
      <input id="regEmail" class="input" type="email" placeholder="Email" />
      <button id="btnRegistrar" class="btn btn--confirm" type="button" style="width:100%;">Registrarme</button>
    </div>

    <div id="msgError" class="muted" style="margin-top:14px;color:var(--danger);text-align:center;font-size:13px;"></div>
  </div>

  <script src="/login.js"></script>
</div>
